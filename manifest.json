{
  "manifest_version": 3,
  "name": "Wikipedia Picture of the Day",
  "version": "1.0",
  "description": "Displays the Wikipedia Picture of the Day in a new tab.",
  "chrome_url_overrides": {
    "newtab": "new_tab.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.wikimedia.org/*",
    "*://*.wikipedia.org/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; media-src 'self' https://upload.wikimedia.org;"
  }
}